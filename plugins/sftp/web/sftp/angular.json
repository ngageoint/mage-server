{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": ".",
  "projects": {
    "admin": {
      "projectType": "library",
      "root": "admin",
      "sourceRoot": "admin/src",
      "prefix": "sftp",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-ng-packagr:build",
          "options": {
            "tsConfig": "admin/tsconfig.lib.json",
            "project": "admin/ng-package.json",
          },
          "configurations": {
            "production": {
              "tsConfig": "admin/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "admin/src/test.ts",
            "tsConfig": "admin/tsconfig.spec.json",
            "karmaConfig": "admin/karma.conf.js",
            "preserveSymlinks": true
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "admin/tsconfig.lib.json",
              "admin/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    }
  },
  "defaultProject": "admin"
}